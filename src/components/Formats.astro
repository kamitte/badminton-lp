---
const formats = [
  {
    title: 'トーナメント',
    description: 'シングルエリミネーション方式。3位決定戦のオプション付きで、少人数から大規模大会まで対応します。',
    badge: '3位決定戦対応',
    icon: 'tournament',
  },
  {
    title: 'リーグ戦',
    description: '総当たり戦方式。参加者数に応じてブロック分けが可能。各ブロックの順位を自動計算します。',
    badge: 'ブロック分け対応',
    icon: 'league',
  },
  {
    title: 'リーグ→トーナメント',
    description: '予選をリーグ戦、決勝をトーナメントで行うハイブリッド形式。公平性と盛り上がりを両立します。',
    badge: 'ハイブリッド形式',
    icon: 'hybrid',
  },
];
---

<section id="formats" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">対応する競技形式</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        大会の規模や目的に合わせて、最適な形式を選べます
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {formats.map((format) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center transition-shadow hover:shadow-lg">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-accent-500/10 text-accent-600">
            {format.icon === 'tournament' && (
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4v4h4M4 8h8M12 4v4M12 8h8M20 4v4h-4M4 16v4h4M4 16h8M12 20v-4M12 16h8M20 16v4h-4M12 8v8" />
              </svg>
            )}
            {format.icon === 'league' && (
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" />
                <path d="M3 9h18M3 15h18M9 3v18M15 3v18" />
              </svg>
            )}
            {format.icon === 'hybrid' && (
              <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="7" height="7" rx="1" />
                <rect x="14" y="3" width="7" height="7" rx="1" />
                <path d="M6.5 10v2h11v-2M12 12v3M8 18h8l-4-3-4 3z" />
              </svg>
            )}
          </div>
          <h3 class="mt-6 text-xl font-bold text-slate-900">{format.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{format.description}</p>
          <span class="mt-4 inline-block rounded-full bg-accent-500/10 px-3 py-1 text-xs font-medium text-accent-600">
            {format.badge}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
