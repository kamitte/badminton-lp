---
import { Image } from 'astro:assets';
import drawImage from '../assets/screenshots/draw.png';
import scoreImage from '../assets/screenshots/score.png';
import pdfImage from '../assets/screenshots/pdf.png';

const details = [
  {
    title: '直感的な組み合わせ作成',
    description: 'シンプルで迷わず使える組み合わせ画面。予選リーグ・決勝トーナメント方式にも対応。',
    image: drawImage,
    alt: '組み合わせ作成画面のスクリーンショット',
    reversed: false,
  },
  {
    title: 'かんたんスコア入力',
    description: 'クリック操作だけでスコアを素早く記録。入力結果から得失点や順位が自動で計算され、集計の手間がかかりません。',
    image: scoreImage,
    alt: 'スコア入力画面のスクリーンショット',
    reversed: true,
  },
  {
    title: 'スコアシート・賞状のPDF出力',
    description: '試合の進行に合わせて、必要なスコアシートや入賞者の賞状をPDFで動的に出力。大会運営の手書き作業がなくなります。',
    image: pdfImage,
    alt: 'PDF出力機能のスクリーンショット',
    reversed: false,
  },
];
---

<section class="bg-surface py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-4">
    <div class="text-center">
      <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">機能詳細</h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        大会運営の流れに沿った、使いやすい機能を揃えています
      </p>
    </div>

    <div class="mt-16 space-y-20">
      {details.map((detail) => (
        <div class={`flex flex-col items-center gap-10 lg:gap-16 ${detail.reversed ? 'lg:flex-row-reverse' : 'lg:flex-row'}`}>
          <!-- Screenshot -->
          <div class="w-full lg:w-1/2">
            <Image
              src={detail.image}
              alt={detail.alt}
              class="w-full rounded-2xl border border-slate-200 bg-white shadow-lg"
              loading="lazy"
            />
          </div>
          <!-- Text -->
          <div class="w-full lg:w-1/2">
            <h3 class="text-2xl font-bold text-slate-900">{detail.title}</h3>
            <p class="mt-4 text-lg leading-relaxed text-slate-600">{detail.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
